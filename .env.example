# Kopieren nach .env und anpassen: cp .env.example .env

ENVIRONMENT=production
LOG_LEVEL=INFO

# Frontend darf nur von diesen Origins per CORS auf die API zugreifen.
ALLOWED_ORIGINS=["https://toolbox.domain.cc"]

# Redis (Queue + Rate Limiting)
REDIS_URL=redis://toolbox-redis:6379/0

# SQLite Default -- fuer Postgres z.B.:
# DATABASE_URL=postgresql://user:password@toolbox-db:5432/toolbox
DATABASE_URL=sqlite:////data/toolbox.db

# Harte Obergrenzen, siehe docs/ARCHITECTURE.md
DEFAULT_TIMEOUT_SECONDS=10
RATE_LIMIT_PER_MINUTE=30
LOGIN_RATE_LIMIT_PER_MINUTE=10
SCAN_RATE_LIMIT_PER_MINUTE=5

# --- Auth ---
# WICHTIG: echten Secret generieren, NICHT den Default verwenden:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=changeme-generate-a-real-secret

# Muss exakt zur oeffentlichen Domain passen, sonst schlaegt WebAuthn/Passkey fehl
WEBAUTHN_RP_ID=toolbox.domain.cc
WEBAUTHN_RP_NAME=Toolbox
WEBAUTHN_ORIGIN=https://toolbox.domain.cc
